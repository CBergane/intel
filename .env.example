DJANGO_ENV=dev
DEBUG=1
SECRET_KEY=replace-me
ALLOWED_HOSTS=127.0.0.1,localhost
WHITENOISE_ENABLED=1

# Leave DB_ENGINE blank to use local sqlite for quick start.
# For Postgres, set DB_ENGINE=django.db.backends.postgresql and fill vars below.
DB_ENGINE=
DB_NAME=intel
DB_USER=intel
DB_PASSWORD=intel
DB_HOST=127.0.0.1
DB_PORT=5432

INTEL_USER_AGENT=borealsec-intel-bot/0.1 (+https://borealsec.io)
INTEL_FETCH_TIMEOUT=10
# Global hard cap for feed response size in bytes
FEED_MAX_BYTES=1500000
# Backward-compatible alias (optional)
INTEL_FETCH_MAX_BYTES=1500000
INTEL_FETCH_RETRIES=3

# Use socks5h so DNS also goes through Tor. In Podman compose this is often socks5h://tor:9050.
DARK_TOR_SOCKS_URL=socks5h://127.0.0.1:9050
DARK_FETCH_TIMEOUT=20
DARK_MAX_BYTES=750000
DARK_FETCH_RETRIES=3
DARK_INDEX_MAX_LINKS=30

EPSS_MAX_RESULTS=200
EPSS_MIN_SCORE=0.1

DARK_DISCORD_WEBHOOK=
INTEL_DISCORD_WEBHOOK=
EPSS_ALERT_THRESHOLD=0.7

TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050
TOR_ENABLED=true

RANSOMWARE_LIVE_NORDICS_ONLY=true

# Comma-separated search queries for psbdmp paste monitoring
PSBDMP_QUERIES=.se password,.se credentials,sweden leak,nordic breach

# HIBP domain breach check
HIBP_API_KEY=
# Comma-separated domains to check, e.g. example.com,example.se
HIBP_DOMAINS=
